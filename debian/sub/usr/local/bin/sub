#!/usr/bin/env bash
# sub — Polyglot unified dispatcher
# Wires: Python · C · Rust · Kotlin · Java · Haxe · CUDA · ASM · M4 · Bash
# Author: Subhobhai (subhobhai943)
# Usage:  sub <command> [args...]

set -euo pipefail

# ── Resolve repo root (works via PATH or direct call) ────────────────
SELF="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
ROOT="$(cd "$(dirname "$SELF")" && pwd)"
BIN="${SUB_BIN:-/usr/local/lib/sub/bin}"
PY="/usr/local/lib/sub/sub.py"

# ── ANSI ─────────────────────────────────────────────────────────────
R="\033[91m" G="\033[92m" Y="\033[93m" C="\033[96m" W="\033[97m" D="\033[2m" RST="\033[0m"

has()     { command -v "$1" &>/dev/null; }
bin()     { [ -x "${BIN}/$1" ]; }
jar()     { [ -f "${BIN}/$1" ]; }
java_ok() { has java; }
py()      { python3 "$PY" "$@"; }

# ── Helper: run a jar ─────────────────────────────────────────────────
run_jar() { java -jar "${BIN}/$1" "${@:2}"; }
run_java_class() { java -cp "${BIN}" "$@"; }

CMD="${1:-help}"; shift || true

case "$CMD" in

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# WEATHER  →  Pure Bash + curl + wttr.in (no API key, no build needed)
#   Usage:  sub weather            → auto-detect city from IP
#           sub weather <city>     → weather for a specific city
#           sub weather <city> -v  → verbose (full wttr.in report)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  weather)
    if ! has curl; then
      echo -e "${R}[!] weather needs curl — run: sudo apt install curl${RST}"
      exit 1
    fi
    CITY="${1:-}"
    VERBOSE=false
    shift || true
    for arg in "$@"; do
      [ "$arg" = "-v" ] || [ "$arg" = "--verbose" ] && VERBOSE=true
    done

    if [ -z "$CITY" ]; then
      CITY="$(curl -sf "https://ipinfo.io/city" 2>/dev/null || echo "")"
      if [ -z "$CITY" ]; then
        echo -e "${Y}[!] Could not detect city. Using default (London).${RST}"
        CITY="London"
      else
        echo -e "${D}[auto-detected city: ${CITY}]${RST}"
      fi
    fi

    CITY_ENC="${CITY// /+}"

    if $VERBOSE; then
      echo -e "${C}[weather / Bash+curl]${RST}  wttr.in verbose report for: ${W}${CITY}${RST}\n"
      curl -sf "https://wttr.in/${CITY_ENC}?T" || echo -e "${R}[!] Failed to fetch weather.${RST}"
    else
      echo -e "${C}[weather / Bash+curl]${RST}  live weather for: ${W}${CITY}${RST}\n"
      RAW="$(curl -sf "https://wttr.in/${CITY_ENC}?format=j1" 2>/dev/null)" || RAW=""
      if [ -z "$RAW" ]; then
        echo -e "${R}[!] Failed to fetch weather data. Check your internet connection.${RST}"
        exit 1
      fi
      COND="$(echo "$RAW"  | grep -o '"weatherDesc".*' | head -1 | grep -o '"value":"[^"]*"' | grep -o '[^"]*"$' | tr -d '"')"
      TEMP_C="$(echo "$RAW" | grep -o '"temp_C":"[^"]*"' | head -1 | grep -o '[0-9\-]*')"
      TEMP_F="$(echo "$RAW" | grep -o '"temp_F":"[^"]*"' | head -1 | grep -o '[0-9\-]*')"
      FEELS_C="$(echo "$RAW" | grep -o '"FeelsLikeC":"[^"]*"' | head -1 | grep -o '[0-9\-]*')"
      HUMIDITY="$(echo "$RAW" | grep -o '"humidity":"[^"]*"' | head -1 | grep -o '[0-9]*')"
      WIND_KMH="$(echo "$RAW" | grep -o '"windspeedKmph":"[^"]*"' | head -1 | grep -o '[0-9]*')"
      WIND_DIR="$(echo "$RAW" | grep -o '"winddir16Point":"[^"]*"' | head -1 | grep -o '"value":"[^"]*"' | grep -o '[^"]*"$' | tr -d '"')"
      SUNRISE="$(echo "$RAW"  | grep -o '"sunrise":"[^"]*"' | head -1 | grep -o '[^"]*"$' | tr -d '"')"
      SUNSET="$(echo "$RAW"   | grep -o '"sunset":"[^"]*"'  | head -1 | grep -o '[^"]*"$' | tr -d '"')"
      PRECIP="$(echo "$RAW"   | grep -o '"precipMM":"[^"]*"' | head -1 | grep -o '[0-9.]*')"
      UV="$(echo "$RAW"       | grep -o '"uvIndex":"[^"]*"' | head -1 | grep -o '[0-9]*')"
      VISIBILITY="$(echo "$RAW" | grep -o '"visibility":"[^"]*"' | head -1 | grep -o '[0-9]*')"

      echo -e "  ${W}Condition  ${RST}: ${COND}"
      echo -e "  ${W}Temp       ${RST}: ${G}${TEMP_C}°C${RST} / ${Y}${TEMP_F}°F${RST}   (feels like ${FEELS_C}°C)"
      echo -e "  ${W}Humidity   ${RST}: ${HUMIDITY}%"
      echo -e "  ${W}Wind       ${RST}: ${WIND_KMH} km/h ${WIND_DIR}"
      echo -e "  ${W}Precip     ${RST}: ${PRECIP} mm"
      echo -e "  ${W}Visibility ${RST}: ${VISIBILITY} km"
      echo -e "  ${W}UV Index   ${RST}: ${UV}"
      echo -e "  ${W}Sunrise    ${RST}: ${SUNRISE}   ${W}Sunset${RST}: ${SUNSET}"
      echo
      echo -e "  ${D}Full report: sub weather ${CITY} -v${RST}"
    fi
    ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PORTS / SCAN  →  C sub-scan (fastest, non-blocking + banner grab)
#                   Kotlin sub-net.jar (threaded fallback)
#                   Python sub.py (final fallback)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  ports|scan)
    if bin sub-scan; then
      echo -e "${C}[sub-scan / C]${RST}  fast non-blocking scanner"
      "${BIN}/sub-scan" "$@"
    elif jar sub-net.jar && java_ok; then
      echo -e "${C}[sub-net / Kotlin]${RST}  threaded scanner"
      T="${1:-}"; S="${2:-1}"; E="${3:-1024}"
      run_jar sub-net.jar scan "$T" "$S" "$E"
    else
      py ports "$@"
    fi ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# BANNER-GRAB   →  Kotlin sub-net (multi-line reader)  →  Python
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  banner-grab|banner-net)
    if jar sub-net.jar && java_ok; then
      echo -e "${C}[sub-net / Kotlin]${RST}  banner grab"
      run_jar sub-net.jar banner "$@"
    else
      py banner-grab "$@"
    fi ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# TRACEROUTE    →  Kotlin  →  Python
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  traceroute)
    if jar sub-net.jar && java_ok; then
      echo -e "${C}[sub-net / Kotlin]${RST}  traceroute"
      run_jar sub-net.jar traceroute "$@"
    else
      py traceroute "$@"
    fi ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GEOIP         →  Kotlin (ip-api.com, no key)  →  Python ipinfo
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  geoip)
    if jar sub-net.jar && java_ok; then
      echo -e "${C}[sub-net / Kotlin]${RST}  geoip"
      run_jar sub-net.jar geoip "$@"
    else
      py ipinfo "$@"
    fi ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RDNS / IFACES →  Kotlin only
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  rdns)
    if jar sub-net.jar && java_ok; then
      run_jar sub-net.jar rdns "$@"
    else echo -e "${R}[!] rdns needs sub-net.jar — run: make kotlin_core_build${RST}"; fi ;;

  ifaces)
    if jar sub-net.jar && java_ok; then
      run_jar sub-net.jar ifaces
    else
      py sysinfo
    fi ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# HASHID        →  Rust sub-recon (zero deps)  →  Python
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  hashid)
    if bin sub-recon; then
      echo -e "${C}[sub-recon / Rust]${RST}  hash identifier"
      "${BIN}/sub-recon" hashid "$@"
    else py hashid "$@"; fi ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# PWCHECK       →  Rust only
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  pwcheck)
    if bin sub-recon; then
      echo -e "${C}[sub-recon / Rust]${RST}  password strength"
      "${BIN}/sub-recon" pwcheck "$@"
    else echo -e "${R}[!] pwcheck needs sub-recon — run: make rust_build${RST}"; fi ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SUBDOMAIN     →  Rust (TCP-connect probe, fast)  →  Python
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  subdomain)
    if bin sub-recon; then
      echo -e "${C}[sub-recon / Rust]${RST}  subdomain probe"
      "${BIN}/sub-recon" subdomain "$@"
    else py subdomain "$@"; fi ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CAESAR / B64  →  Rust
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  caesar)
    if bin sub-recon; then "${BIN}/sub-recon" caesar "$@"
    else echo -e "${R}[!] caesar needs sub-recon — run: make rust_build${RST}"; fi ;;

  b64)
    if bin sub-recon; then "${BIN}/sub-recon" b64 "$@"
    else py encode "$@" --mode b64; fi ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SYSINFO       →  ASM sub-sysinfo (bare metal)  →  Python
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  sysinfo)
    if bin sub-sysinfo; then
      echo -e "${C}[sub-sysinfo / ASM]${RST}  native sysinfo"
      "${BIN}/sub-sysinfo"
    elif bin sub-asm; then
      echo -e "${C}[sub-asm / ASM]${RST}  native sysinfo"
      "${BIN}/sub-asm"
    else py sysinfo; fi ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GPUINFO  →  CUDA sub-cuda (full kernel launch, needs nvcc + GPU)
#             nvidia-smi  (NVIDIA driver, no nvcc needed)
#             lspci       (any GPU, PCI bus scan, no driver needed)
#             sysfs       (/sys/class/drm, last resort)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  gpuinfo|cuda)
    if bin sub-cuda; then
      echo -e "${C}[sub-cuda / CUDA C++]${RST}  GPU info + kernel demo"
      "${BIN}/sub-cuda" gpuinfo

    elif has nvidia-smi; then
      echo -e "${C}[gpuinfo / nvidia-smi]${RST}  NVIDIA driver detected (no CUDA build needed)\n"
      # Header line
      echo -e "  ${Y}NVIDIA GPU(s)${RST}"
      echo -e "  ${D}────────────────────────────────────────${RST}"
      # Full query: name, driver, VRAM total/used/free, temp, utilization, clock
      nvidia-smi --query-gpu=\
index,name,driver_version,memory.total,memory.used,memory.free,\
temperature.gpu,utilization.gpu,utilization.memory,\
clocks.current.graphics,clocks.current.memory,pstate \
        --format=csv,noheader,nounits 2>/dev/null \
      | while IFS=, read -r idx name drv mem_tot mem_used mem_free temp util_gpu util_mem clk_g clk_m pstate; do
          echo -e "  ${W}GPU ${idx}${RST}: ${G}${name}${RST}"
          echo -e "    Driver         : ${drv}"
          echo -e "    VRAM           : ${G}${mem_tot} MiB${RST} total   ${Y}${mem_used} MiB${RST} used   ${mem_free} MiB free"
          echo -e "    Temperature    : ${temp} °C"
          echo -e "    GPU Util       : ${util_gpu}%   Mem Util: ${util_mem}%"
          echo -e "    Clocks         : ${clk_g} MHz (graphics)   ${clk_m} MHz (memory)"
          echo -e "    Power State    : ${pstate}"
          echo
        done
      echo -e "  ${D}Tip: run 'make cuda_build' for full CUDA kernel demo${RST}"

    elif has lspci; then
      echo -e "${C}[gpuinfo / lspci]${RST}  PCI bus scan (no driver needed)\n"
      echo -e "  ${Y}GPU device(s) detected:${RST}"
      echo -e "  ${D}────────────────────────────────────────${RST}"
      GPU_LINES="$(lspci 2>/dev/null | grep -iE 'vga|3d|display|nvidia|amd|radeon|intel.*graphics' || true)"
      if [ -z "$GPU_LINES" ]; then
        echo -e "  ${R}[!] No GPU found via lspci.${RST}"
      else
        echo "$GPU_LINES" | while IFS= read -r line; do
          echo -e "  ${G}→${RST} ${line}"
        done
        echo
        # Try to read driver from sysfs for each PCI id
        echo -e "  ${D}Driver info (if loaded):${RST}"
        lspci -k 2>/dev/null | grep -A3 -iE 'vga|3d|display' \
          | grep -E 'Kernel driver|Kernel modules' \
          | sed 's/^/    /' || echo "    (no driver info available)"
      fi
      echo
      echo -e "  ${D}Tip: install nvidia-smi or nvcc for richer GPU info${RST}"

    elif [ -d /sys/class/drm ]; then
      echo -e "${C}[gpuinfo / sysfs]${RST}  DRM subsystem scan\n"
      echo -e "  ${Y}DRM render nodes:${RST}"
      echo -e "  ${D}────────────────────────────────────────${RST}"
      FOUND=false
      for card in /sys/class/drm/card[0-9]*; do
        [ -d "$card" ] || continue
        FOUND=true
        NAME="$(cat "${card}/device/product_name" 2>/dev/null \
             || cat "${card}/device/uevent" 2>/dev/null | grep PCI_ID | head -1 \
             || basename "$card")"
        VENDOR="$(cat "${card}/device/vendor" 2>/dev/null || echo 'unknown')"
        DRIVER="$(basename "$(readlink -f "${card}/device/driver" 2>/dev/null)" 2>/dev/null || echo 'none')"
        echo -e "  ${G}→${RST} $(basename $card)   vendor: ${VENDOR}   driver: ${DRIVER}   (${NAME})"
      done
      $FOUND || echo -e "  ${R}[!] No DRM cards found.${RST}"
      echo
      echo -e "  ${D}Tip: install lspci (pciutils) for better GPU info${RST}"

    else
      echo -e "${Y}[gpuinfo / no hardware tools found]${RST}\n"
      echo -e "  Could not find any of: ${W}sub-cuda${RST}  ${W}nvidia-smi${RST}  ${W}lspci${RST}  ${W}/sys/class/drm${RST}\n"
      echo -e "  To get GPU info, install one of:"
      echo -e "    ${G}sudo apt install pciutils${RST}          (adds lspci, works for any GPU)"
      echo -e "    ${G}sudo apt install nvidia-utils-XXX${RST}  (adds nvidia-smi, NVIDIA only)"
      echo -e "    ${G}make cuda_build${RST}                    (needs nvcc + NVIDIA GPU)"
    fi
    ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# WHOAMI        →  M4 pre-rendered txt  (fastest, zero runtime)
#                   Haxe sub-haxe       (cross-platform compiled)
#                   CUDA sub-cuda       (GPU whoami)
#                   Kotlin sub-kt.jar   (JVM)
#                   Java  Sub.class     (JVM)
#                   Python sub.py       (final fallback)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  whoami)
    if [ -f "${BIN}/sub-whoami.txt" ]; then
      echo -e "${C}[M4 macro]${RST}  pre-rendered whoami"
      cat "${BIN}/sub-whoami.txt"
    elif bin sub-haxe; then
      echo -e "${C}[sub-haxe / Haxe→C++]${RST}"
      "${BIN}/sub-haxe" whoami
    elif bin sub-cuda; then
      echo -e "${C}[sub-cuda / CUDA C++]${RST}"
      "${BIN}/sub-cuda" whoami
    elif jar sub-kt.jar && java_ok; then
      echo -e "${C}[sub-kt / Kotlin]${RST}"
      run_jar sub-kt.jar whoami
    elif [ -f "${BIN}/Sub.class" ] && java_ok; then
      echo -e "${C}[Sub / Java]${RST}"
      run_java_class Sub whoami
    else
      py whoami
    fi ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# BANNER (ascii art)  →  CUDA  →  Haxe  →  Kotlin  →  Java  →  Python
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  banner)
    if bin sub-cuda; then   "${BIN}/sub-cuda" banner
    elif bin sub-haxe; then "${BIN}/sub-haxe" banner
    elif jar sub-kt.jar && java_ok; then run_jar sub-kt.jar banner
    elif [ -f "${BIN}/Sub.class" ] && java_ok; then run_java_class Sub banner
    else py banner; fi ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# INFO (sysinfo variant)  →  Kotlin sub-kt  →  Java Sub  →  Python
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  info)
    if jar sub-kt.jar && java_ok; then
      echo -e "${C}[sub-kt / Kotlin]${RST}  system info"
      run_jar sub-kt.jar info
    elif [ -f "${BIN}/Sub.class" ] && java_ok; then
      echo -e "${C}[Sub / Java]${RST}  system info"
      run_java_class Sub info
    elif bin sub-haxe; then
      echo -e "${C}[sub-haxe / Haxe]${RST}  system info"
      "${BIN}/sub-haxe" info
    else
      py sysinfo
    fi ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# M4 (raw macro expansion)  →  prints sub-whoami.txt or runs m4
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  m4|macro)
    if [ -f "${BIN}/sub-whoami.txt" ]; then
      cat "${BIN}/sub-whoami.txt"
    elif has m4; then
      m4 "${ROOT}/src/m4/sub.m4"
    else
      echo -e "${R}[!] m4 not found — run: sudo apt install m4${RST}"
    fi ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# BUILD / CHECK helpers exposed as sub commands
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  build)       make -C "$ROOT" build ;;
  check-tools) make -C "$ROOT" check ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# HELP  →  Python master help + native backend status overlay
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  help|-h|--help)
    py help
    echo
    echo -e "  ${Y}─── Native Backends ────────────────────────────────────────${RST}"
    _st() { [ -e "${BIN}/$1" ] && echo -e "${G}built${RST}" || echo -e "${R}not built${RST}"; }
    echo -e "  ${C}sub-scan${RST}      C / gcc          ports scan          $(_st sub-scan)"
    echo -e "  ${C}sub-recon${RST}     Rust / rustc      hashid pwcheck      $(_st sub-recon)"
    echo -e "                                subdomain caesar b64"
    echo -e "  ${C}sub-net.jar${RST}   Kotlin / kotlinc  banner traceroute   $(_st sub-net.jar)"
    echo -e "                                geoip rdns ifaces"
    echo -e "  ${C}sub-kt.jar${RST}    Kotlin / kotlinc  whoami info         $(_st sub-kt.jar)"
    echo -e "  ${C}Sub.class${RST}     Java / javac      whoami info ports   $(_st Sub.class)"
    echo -e "  ${C}sub-haxe${RST}      Haxe→C++ / haxe   whoami banner info  $(_st sub-haxe)"
    echo -e "  ${C}sub-cuda${RST}      CUDA C++ / nvcc   gpuinfo whoami      $(_st sub-cuda)"
    echo -e "  ${C}sub-asm${RST}       NASM/GAS / nasm   sysinfo             $(_st sub-asm)"
    echo -e "  ${C}sub-sysinfo${RST}   NASM / nasm       sysinfo             $(_st sub-sysinfo)"
    echo -e "  ${C}sub-whoami.txt${RST} M4 macros / m4   whoami (static)     $(_st sub-whoami.txt)"
    echo -e "  ${C}weather${RST}       Pure Bash + curl  live weather        always available"
    echo -e "  ${C}gpuinfo${RST}       Bash fallback      nvidia-smi/lspci   always available"
    echo
    echo -e "  New commands:  ${W}gpuinfo${RST}  ${W}geoip${RST}  ${W}rdns${RST}  ${W}ifaces${RST}  ${W}pwcheck${RST}  ${W}caesar${RST}  ${W}b64${RST}  ${W}m4${RST}  ${W}info${RST}  ${W}weather${RST}"
    echo -e "  Run ${W}sub build${RST} or ${W}make${RST} to compile all backends."
    echo -e "  Run ${W}sub check-tools${RST} to audit toolchain + built binaries."
    echo ;;

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# EVERYTHING ELSE  →  Python master CLI
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
  *) py "$CMD" "$@" ;;
esac
